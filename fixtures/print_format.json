[
  {
    "name": "Sales Billing Statement",
    "doc_type": "Sales",
    "module": "Selling",
    "print_format_type": "Jinja",
    "standard": "No",
    "disabled": 0,
    "custom_format": 0,
    "html": "<style>\n    .billing-statement {\n        font-family: Arial, sans-serif;\n        font-size: 12px;\n        line-height: 1.4;\n        color: #000;\n        padding: 20px;\n    }\n    .billing-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 20px;\n    }\n    .billing-table th, .billing-table td {\n        border: 1px solid #000;\n        padding: 6px;\n    }\n    .billing-table th {\n        text-align: center;\n        font-weight: bold;\n        background-color: #f2f2f2;\n    }\n    .text-center { text-align: center; }\n    .text-right { text-align: right; }\n    .signature-box { border-bottom: 1px solid #000; height: 30px; margin-bottom: 5px; }\n</style>\n\n<div class=\"billing-statement\">\n    <h3 class=\"text-center\" style=\"margin-bottom: 20px; text-transform: uppercase;\">Billing Statement</h3>\n    \n    <table style=\"width: 100%; margin-bottom: 20px; border-collapse: collapse;\">\n        <tr>\n            <td style=\"width: 60%; vertical-align: top; padding-right: 15px;\">\n                <div style=\"margin-bottom: 10px;\">\n                    <strong>Customer:</strong> {{ doc.customer_name or \"Unknown Customer\" }}<br>\n                    <strong>Address:</strong> {{ doc.address or \"No Address Provided\" }}\n                </div>\n            </td>\n            <td style=\"width: 40%; vertical-align: top; border-left: 1px solid #eee; padding-left: 15px;\">\n                <strong>Date:</strong> {{ frappe.utils.formatdate(doc.creation_date) if doc.creation_date else '' }}<br>\n                <strong>S.O. No.:</strong> {{ doc.name }}<br>\n                <strong>Ref. No.:</strong> {{ doc.order_ref or '' }}<br>\n                <strong>Terms:</strong> {{ doc.terms or '' }}<br>\n                <strong>Salesman:</strong>\n                {% set s_man_id = frappe.db.get_value(\"Order Form\", doc.order_ref, \"owner\") if doc.order_ref else doc.owner %}\n                {% if s_man_id %}\n                    {{ frappe.db.get_value(\"User\", s_man_id, \"full_name\") or s_man_id }}\n                {% endif %}\n            </td>\n        </tr>\n    </table>\n\n    <table class=\"billing-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 15%;\">QTY</th>\n                <th style=\"width: 15%;\">U/M</th>\n                <th style=\"width: 55%;\">Item Description</th>\n                <th style=\"width: 15%;\">WH</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% set total_qty_obj = {'val': 0} %}\n            {% for item in (doc.items or []) %}\n                {% set _ = total_qty_obj.update({'val': total_qty_obj.val + (item.qty | float)}) %}\n                <tr>\n                    <td class=\"text-center\">{{ item.qty }}</td>\n                    <td class=\"text-center\">{{ item.unit or 'PCS' }}</td>\n                    <td>{{ item.item }}</td>\n                    <td class=\"text-center\">{{ item.warehouse or '' }}</td>\n                </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n    <div style=\"margin-bottom: 40px;\">\n        <strong>Total Qty.:</strong> {{ total_qty_obj.val }}\n    </div>\n\n    <table style=\"width: 100%; text-align: center; border-collapse: collapse; table-layout: fixed;\">\n        <tr>\n            <td style=\"padding: 0 10px;\">\n                <div class=\"signature-box\"></div>\n                <div style=\"font-size: 10px;\">Prepared by</div>\n            </td>\n            <td style=\"padding: 0 10px;\">\n                <div class=\"signature-box\"></div>\n                <div style=\"font-size: 10px;\">Checked by</div>\n            </td>\n            <td style=\"padding: 0 10px;\">\n                <div class=\"signature-box\"></div>\n                <div style=\"font-size: 10px;\">Approved by</div>\n            </td>\n            <td style=\"padding: 0 10px;\">\n                <div class=\"signature-box\"></div>\n                <div style=\"font-size: 10px;\">\n                    {% if doc.fulfillment_type == 'Pick-up' %}\n                        Received by\n                    {% else %}\n                        Delivered by\n                    {% endif %}\n                </div>\n            </td>\n        </tr>\n    </table>\n</div>",
    "line_breaks": 0,
    "align_labels_right": 0,
    "show_section_headings": 0,
    "print_format_builder_beta": 0,
