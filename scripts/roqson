#!/bin/zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

cmd="${1:-}"

case "$cmd" in
  refresh)
    shift || true
    "$ROOT_DIR/scripts/workshop-refresh.sh" "${1:-all}"
    ;;
  *)
    cat <<'EOF'
Usage:
  roqson refresh
  roqson refresh all
  roqson refresh python
  roqson refresh assets
  roqson refresh workspace
EOF
    exit 1
    ;;
esac
