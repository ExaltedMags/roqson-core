#!/usr/bin/env bash
set -euo pipefail

BENCH_PATH="${ROQSON_BENCH_PATH:-/Users/kodimagadia/frappe-dev/frappe-bench}"
SITE_NAME="${ROQSON_SITE_NAME:-roqson.local}"

if [[ ! -d "$BENCH_PATH" ]]; then
  echo "Bench path not found: $BENCH_PATH" >&2
  echo "Set ROQSON_BENCH_PATH if your bench moved." >&2
  exit 1
fi

if [[ ! -d "$BENCH_PATH/sites/$SITE_NAME" ]]; then
  echo "Site not found: $SITE_NAME" >&2
  echo "Set ROQSON_SITE_NAME if you want a different site." >&2
  exit 1
fi

echo "Refreshing $SITE_NAME in $BENCH_PATH"
cd "$BENCH_PATH"

bench --site "$SITE_NAME" clear-cache
bench --site "$SITE_NAME" clear-website-cache
bench --site "$SITE_NAME" migrate

echo
echo "Refresh complete for $SITE_NAME"
